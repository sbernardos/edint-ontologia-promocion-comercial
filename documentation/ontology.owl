     -->


    


    <!-- http://schema.org/address -->


    <owl:ObjectProperty rdf:about="http://schema.org/address">
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal"/>
    </owl:ObjectProperty>
    


    <!-- http://schema.org/eventSchedule -->


    <owl:ObjectProperty rdf:about="http://schema.org/eventSchedule">
        <rdfs:isDefinedBy rdf:resource="http://schema.org/"/>
    </owl:ObjectProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#finTramo -->


    <owl:ObjectProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#finTramo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/sf#Point"/>
        <rdfs:comment xml:lang="es">Relación del tramo con el lugar donde finaliza el tramo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship of the section with the point where it ends.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">Fin del Tramo</rdfs:label>
        <rdfs:label xml:lang="en">Section end</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#inicioTramo -->


    <owl:ObjectProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#inicioTramo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/sf#Point"/>
        <rdfs:comment xml:lang="es">Relación del tramo con el lugar donde se inicia el tramo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship of the section with the point where it starts.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">Inicio del Tramo</rdfs:label>
        <rdfs:label xml:lang="en">Section start</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#locatedInZone -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#locatedInZone">
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#"/>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion#hasCommercialCampaignType -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion#hasCommercialCampaignType">
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/CommercialCampaignType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">It relates an entity, especially a commercial campaign, to a skos concept that is in the commercial campaing type taxonomy.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una entidad, principalmente una campaña comercial, con un concepto skos que está en la taxonomía del tipo de campaña comercial.</rdfs:comment>
        <rdfs:label xml:lang="en">has commercial campaign type</rdfs:label>
        <rdfs:label xml:lang="es">tiene tipo de campaña comercial</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion#hasCommercialEventType -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion#hasCommercialEventType">
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/CommercialEventType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">It relates an entity, especially a commercial event, to a skos concept that is in the commercial event type taxonomy.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una entidad, principalmente un evento comercial, con un concepto skos que está en la taxonomía del tipo de evento comercial.</rdfs:comment>
        <rdfs:label xml:lang="en">has commercial event campaign</rdfs:label>
        <rdfs:label xml:lang="es">tiene tipo de evento comercial</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/common/zone#locatedIn -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#locatedIn">
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#"/>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#municipio -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#municipio">
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio"/>
        <rdfs:comment xml:lang="es">Municipio al que pertenece un fenómeno geográfico o una entidad administrativa</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio"/>
        <rdfs:label xml:lang="es">pertenece a municipio</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contienePortal -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contienePortal">
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Portal"/>
        <rdfs:comment xml:lang="es">Portal que un fenómeno geográfico contiene (por ejemplo, una vía o un tramo de vía, aunque también puede ser un barrio, distrito, ciudad, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero"/>
        <rdfs:label xml:lang="es">contiene portal</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contieneVia -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contieneVia">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#sfContains"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Via"/>
        <terms:issued>2014-03-28</terms:issued>
        <rdfs:comment xml:lang="es">Vía que un fenómeno geográfico contiene (por ejemplo, un barrio, distrito, ciudad, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero"/>
        <rdfs:label xml:lang="es">contiene vía</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.geonames.org/ontology#featureClass -->


    <owl:ObjectProperty rdf:about="http://www.geonames.org/ontology#featureClass"/>
    


    <!-- http://www.geonames.org/ontology#featureCode -->


    <owl:ObjectProperty rdf:about="http://www.geonames.org/ontology#featureCode"/>
    


    <!-- http://www.opengis.net/ont/geosparql#hasGeometry -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasGeometry">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:comment xml:lang="es">Una representación espacial de un &quot;feature&quot; determinado.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0"/>
        <rdfs:label xml:lang="en">has geometry</rdfs:label>
        <rdfs:label xml:lang="es">tiene geometría</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#sfContains -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#sfContains"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#hasBeginning -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasBeginning">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2006/time#hasTime"/>
        <rdfs:comment xml:lang="en">Beginning of a temporal entity</rdfs:comment>
        <rdfs:comment xml:lang="es">Comienzo de una entidad temporal.</rdfs:comment>
        <rdfs:label xml:lang="en">has beginning</rdfs:label>
        <rdfs:label xml:lang="es">tiene principio</rdfs:label>
        <skos:definition xml:lang="en">Beginning of a temporal entity.</skos:definition>
        <skos:definition xml:lang="es">Comienzo de una entidad temporal.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#hasEnd -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasEnd">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2006/time#hasTime"/>
        <rdfs:comment xml:lang="en">End of a temporal entity.</rdfs:comment>
        <rdfs:comment xml:lang="es">Final de una entidad temporal.</rdfs:comment>
        <rdfs:label xml:lang="en">has end</rdfs:label>
        <rdfs:label xml:lang="es">tiene fin</rdfs:label>
        <skos:definition xml:lang="en">End of a temporal entity.</skos:definition>
        <skos:definition xml:lang="es">Final de una entidad temporal.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#hasTime -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasTime"/>
    


