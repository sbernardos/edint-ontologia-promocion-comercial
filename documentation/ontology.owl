    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/identifier -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/identifier">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">An unambiguous reference to the resource within a given context.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una referencia no ambigüa al recurso dentro de un contexto determinado.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="es">identificador</rdfs:label>
        <rdfs:label xml:lang="en">identifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/endDate -->


    <owl:DatatypeProperty rdf:about="http://schema.org/endDate">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="es">La fecha y hora de finalización del elemento (en formato de fecha ISO 8601).</rdfs:comment>
        <rdfs:comment xml:lang="en">The end date and time of the item (in ISO 8601 date format).</rdfs:comment>
        <rdfs:comment xml:lang="en">end date</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://schema.org"/>
        <rdfs:label xml:lang="es">fecha de finalización</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/name -->


    <owl:DatatypeProperty rdf:about="http://schema.org/name">
        <rdfs:isDefinedBy rdf:resource="http://schema.org/"/>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/openingHours -->


    <owl:DatatypeProperty rdf:about="http://schema.org/openingHours">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">Horario general de apertura de un negocio. El horario se puede especificar como un rango semanal, comenzando por días y luego por horas al día. Se pueden indicar varios días separados por comas (&quot;,&quot;). Los rangos de días u horas se especifican con un guion (-).</rdfs:comment>
        <rdfs:comment xml:lang="en">The general opening hours for a business. Opening hours can be specified as a weekly time range, starting with days, then times per day. Multiple days can be listed with commas &apos;,&apos; separating each day. Day or time ranges are specified using a hyphen &apos;-&apos;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://schema.org"/>
        <rdfs:label xml:lang="es">horario de apertura</rdfs:label>
        <rdfs:label xml:lang="en">opening hours</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/startDate -->


    <owl:DatatypeProperty rdf:about="http://schema.org/startDate">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="es">La fecha y hora de inicio del elemento (en formato de fecha ISO 8601).</rdfs:comment>
        <rdfs:comment xml:lang="en">The start date and time of the item (in ISO 8601 date format).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://schema.org"/>
        <rdfs:label xml:lang="es">fecha de inicio</rdfs:label>
        <rdfs:label xml:lang="en">start date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales/public -->


    <owl:DatatypeProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales/public">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si una entidad del censo de locales comerciales es pública o no.</rdfs:comment>
        <rdfs:comment xml:lang="en">It points out whether an entity in the commerce census is public or not</rdfs:comment>
        <rdfs:label xml:lang="en">public</rdfs:label>
        <rdfs:label xml:lang="es">público</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion#budget -->


    <owl:DatatypeProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion#budget">
        <rdfs:comment xml:lang="es">Indica la estimación del coste de un evento o similar.</rdfs:comment>
        <rdfs:comment xml:lang="en">It captures an estimate of expenditure for an event or something alike</rdfs:comment>
        <rdfs:label xml:lang="en">budget</rdfs:label>
        <rdfs:label xml:lang="es">presupuesto</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion#numberOfCommercialSpaces -->


    <owl:DatatypeProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion#numberOfCommercialSpaces">
        <rdfs:comment xml:lang="en">It captures the number of commercial spaces joind to a campaign o something alike.</rdfs:comment>
        <rdfs:comment xml:lang="es">indica la cantidad de espacios comerciales adheridos a una campaña o similar.</rdfs:comment>
        <rdfs:label xml:lang="en">number of commercial spaces</rdfs:label>
        <rdfs:label xml:lang="es">número de espacios comerciales</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/2006/time#inXSDgYearMonth -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/2006/time#inXSDgYearMonth">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYearMonth"/>
        <rdfs:comment xml:lang="es">Posición de un instante, expresado utilizando xsd:gYearMonth.</rdfs:comment>
        <rdfs:comment xml:lang="en">Position of an instant, expressed using xsd:gYearMonth</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2006/time#"/>
        <rdfs:label xml:lang="es">en año-mes gregoriano XSD</rdfs:label>
        <rdfs:label xml:lang="en">in XSD g-YearMonth</rdfs:label>
        <skos:definition xml:lang="es">Posición de un instante, expresado utilizando xsd:gYearMonth.</skos:definition>
        <skos:definition xml:lang="en">Position of an instant, expressed using xsd:gYearMonth</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://datos.ign.es/def/geo_core#xETRS89 -->


    <owl:DatatypeProperty rdf:about="https://datos.ign.es/def/geo_core#xETRS89">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/sf#Point"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <dc:source xml:lang="es">Catálogo de Objetos Geográficos BTN100.</dc:source>
        <rdfs:comment xml:lang="es">Coordenada X en metros (ETRS89)</rdfs:comment>
        <rdfs:comment xml:lang="en">X-Coordinate in meters (ETRS89)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://datos.ign.es/def/geo_core#"/>
