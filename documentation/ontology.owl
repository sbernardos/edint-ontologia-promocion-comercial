<?xml version="1.0"?>
<rdf:RDF xmlns="http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion#"
     xml:base="http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:mod="https://w3id.org/mod#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:schema="http://schema.org/">
    <owl:Ontology rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion">
        <owl:versionIRI rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion/0.1.0"/>
        <terms:created>2026-04-15</terms:created>
        <terms:creator>Daniel Doña</terms:creator>
        <terms:creator>Edna Ruckhaus</terms:creator>
        <terms:creator>Lucía Sánchez</terms:creator>
        <terms:creator>Oscar Corcho</terms:creator>
        <terms:creator>Socorro Bernardos</terms:creator>
        <terms:description xml:lang="es">El propósito de esta ontología es proporcionar un vocabulario común para la representación de las entidades y los datos principales relacionados con la promoción comercial, como campañas y eventos.</terms:description>
        <terms:description xml:lang="en">The purpose of this ontology is to provide a common vocabulary for representing the main entities and data related to commecial promotion, such as campaigns and events.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title xml:lang="es">Ontología de Promoción Comercial</terms:title>
        <terms:title xml:lang="en">The Commercial Promotion Ontology</terms:title>
        <vann:preferredNamespacePrefix>edintpro</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion#"/>
        <owl:versionInfo>0.1.0</owl:versionInfo>
    </owl:Ontology>
    


