###  http://schema.org/address
<http://schema.org/address> rdf:type owl:ObjectProperty ;
                            rdfs:range <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal> .


###  http://schema.org/eventSchedule
<http://schema.org/eventSchedule> rdf:type owl:ObjectProperty ;
                                  rdfs:isDefinedBy <http://schema.org/> .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#finTramo
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#finTramo> rdf:type owl:ObjectProperty ,
                                                                            owl:FunctionalProperty ;
                                                                   rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo> ;
                                                                   rdfs:range <http://www.opengis.net/ont/sf#Point> ;
                                                                   rdfs:comment "Relación del tramo con el lugar donde finaliza el tramo."@es ,
                                                                                "Relationship of the section with the point where it ends."@en ;
                                                                   rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                   rdfs:label "Fin del Tramo"@es ,
                                                                              "Section end"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#inicioTramo
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#inicioTramo> rdf:type owl:ObjectProperty ,
                                                                               owl:FunctionalProperty ;
                                                                      rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo> ;
                                                                      rdfs:range <http://www.opengis.net/ont/sf#Point> ;
                                                                      rdfs:comment "Relación del tramo con el lugar donde se inicia el tramo."@es ,
                                                                                   "Relationship of the section with the point where it starts."@en ;
                                                                      rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                      rdfs:label "Inicio del Tramo"@es ,
                                                                                 "Section start"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#locatedInZone
<http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#locatedInZone> rdf:type owl:ObjectProperty ;
                                                                                    rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#> .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion#hasCommercialCampaignType
:hasCommercialCampaignType rdf:type owl:ObjectProperty ;
                           rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                               owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/CommercialCampaignType>
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                           rdfs:comment "It relates an entity, especially a commercial campaign, to a skos concept that is in the commercial campaing type taxonomy."@en ,
                                        "Relaciona una entidad, principalmente una campaña comercial, con un concepto skos que está en la taxonomía del tipo de campaña comercial."@es ;
                           rdfs:label "has commercial campaign type"@en ,
                                      "tiene tipo de campaña comercial"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion#hasCommercialEventType
:hasCommercialEventType rdf:type owl:ObjectProperty ;
                        rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                            owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/CommercialEventType>
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
                        rdfs:comment "It relates an entity, especially a commercial event, to a skos concept that is in the commercial event type taxonomy."@en ,
                                     "Relaciona una entidad, principalmente un evento comercial, con un concepto skos que está en la taxonomía del tipo de evento comercial."@es ;
                        rdfs:label "has commercial event campaign"@en ,
                                   "tiene tipo de evento comercial"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/common/zone#locatedIn
<http://vocab.linkeddata.es/datosabiertos/def/common/zone#locatedIn> rdf:type owl:ObjectProperty ;
                                                                     rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/common/zone#> .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#municipio
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#municipio> rdf:type owl:ObjectProperty ;
                                                                                   rdfs:range <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio> ;
                                                                                   rdfs:comment "Municipio al que pertenece un fenómeno geográfico o una entidad administrativa"@es ;
                                                                                   rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                   rdfs:label "pertenece a municipio"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contienePortal
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contienePortal> rdf:type owl:ObjectProperty ;
                                                                                                   rdfs:range <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Portal> ;
                                                                                                   rdfs:comment "Portal que un fenómeno geográfico contiene (por ejemplo, una vía o un tramo de vía, aunque también puede ser un barrio, distrito, ciudad, etc.)"@es ;
                                                                                                   rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero> ;
                                                                                                   rdfs:label "contiene portal"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contieneVia
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contieneVia> rdf:type owl:ObjectProperty ;
                                                                                                rdfs:subPropertyOf <http://www.opengis.net/ont/geosparql#sfContains> ;
                                                                                                rdfs:range <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Via> ;
                                                                                                <http://purl.org/dc/terms/issued> "2014-03-28" ;
                                                                                                rdfs:comment "Vía que un fenómeno geográfico contiene (por ejemplo, un barrio, distrito, ciudad, etc.)"@es ;
                                                                                                rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero> ;
                                                                                                rdfs:label "contiene vía"@es .


###  http://www.geonames.org/ontology#featureClass
<http://www.geonames.org/ontology#featureClass> rdf:type owl:ObjectProperty .


###  http://www.geonames.org/ontology#featureCode
<http://www.geonames.org/ontology#featureCode> rdf:type owl:ObjectProperty .


###  http://www.opengis.net/ont/geosparql#hasGeometry
<http://www.opengis.net/ont/geosparql#hasGeometry> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain <http://www.opengis.net/ont/geosparql#Feature> ;
                                                   rdfs:range <http://www.opengis.net/ont/geosparql#Geometry> ;
                                                   rdfs:comment "Una representación espacial de un \"feature\" determinado."@es ;
                                                   rdfs:isDefinedBy <http://www.opengis.net/spec/geosparql/1.0> ;
                                                   rdfs:label "has geometry"@en ,
                                                              "tiene geometría"@es .


###  http://www.opengis.net/ont/geosparql#sfContains
<http://www.opengis.net/ont/geosparql#sfContains> rdf:type owl:ObjectProperty .


###  http://www.w3.org/2004/02/skos/core#inScheme
<http://www.w3.org/2004/02/skos/core#inScheme> rdf:type owl:ObjectProperty ;
                                               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core#> .


###  http://www.w3.org/2006/time#hasBeginning
<http://www.w3.org/2006/time#hasBeginning> rdf:type owl:ObjectProperty ;
                                           rdfs:subPropertyOf <http://www.w3.org/2006/time#hasTime> ;
                                           rdfs:comment "Beginning of a temporal entity"@en ,
                                                        "Comienzo de una entidad temporal."@es ;
                                           rdfs:label "has beginning"@en ,
                                                      "tiene principio"@es ;
                                           <http://www.w3.org/2004/02/skos/core#definition> "Beginning of a temporal entity."@en ,
                                                                                            "Comienzo de una entidad temporal."@es .


###  http://www.w3.org/2006/time#hasEnd
<http://www.w3.org/2006/time#hasEnd> rdf:type owl:ObjectProperty ;
                                     rdfs:subPropertyOf <http://www.w3.org/2006/time#hasTime> ;
                                     rdfs:comment "End of a temporal entity."@en ,
                                                  "Final de una entidad temporal."@es ;
                                     rdfs:label "has end"@en ,
                                                "tiene fin"@es ;
                                     <http://www.w3.org/2004/02/skos/core#definition> "End of a temporal entity."@en ,
                                                                                      "Final de una entidad temporal."@es .


###  http://www.w3.org/2006/time#hasTime
<http://www.w3.org/2006/time#hasTime> rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/identifier
<http://purl.org/dc/terms/identifier> rdf:type owl:DatatypeProperty ;
                                      rdfs:range rdfs:Literal ;
                                      rdfs:comment "An unambiguous reference to the resource within a given context."@en ,
                                                   "Una referencia no ambigüa al recurso dentro de un contexto determinado."@es ;
                                      rdfs:isDefinedBy <http://purl.org/dc/terms/> ;
                                      rdfs:label "identificador"@es ,
                                                 "identifier"@en .


###  http://schema.org/endDate
<http://schema.org/endDate> rdf:type owl:DatatypeProperty ;
                            rdfs:range xsd:dateTime ;
                            rdfs:comment "La fecha y hora de finalización del elemento (en formato de fecha ISO 8601)."@es ,
                                         "The end date and time of the item (in ISO 8601 date format)."@en ,
                                         "end date"@en ;
                            rdfs:isDefinedBy <http://schema.org> ;
                            rdfs:label "fecha de finalización"@es .


###  http://schema.org/name
<http://schema.org/name> rdf:type owl:DatatypeProperty ;
                         rdfs:isDefinedBy <http://schema.org/> .


###  http://schema.org/openingHours
<http://schema.org/openingHours> rdf:type owl:DatatypeProperty ;
                                 rdfs:range xsd:string ;
                                 rdfs:comment "Horario general de apertura de un negocio. El horario se puede especificar como un rango semanal, comenzando por días y luego por horas al día. Se pueden indicar varios días separados por comas (\",\"). Los rangos de días u horas se especifican con un guion (-)."@es ,
                                              "The general opening hours for a business. Opening hours can be specified as a weekly time range, starting with days, then times per day. Multiple days can be listed with commas ',' separating each day. Day or time ranges are specified using a hyphen '-'."@en ;
                                 rdfs:isDefinedBy <http://schema.org> ;
                                 rdfs:label "horario de apertura"@es ,
                                            "opening hours"@en .


###  http://schema.org/startDate
<http://schema.org/startDate> rdf:type owl:DatatypeProperty ;
                              rdfs:range xsd:dateTime ;
                              rdfs:comment "La fecha y hora de inicio del elemento (en formato de fecha ISO 8601)."@es ,
                                           "The start date and time of the item (in ISO 8601 date format)."@en ;
                              rdfs:isDefinedBy <http://schema.org> ;
                              rdfs:label "fecha de inicio"@es ,
                                         "start date"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales/public
<http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales/public> rdf:type owl:DatatypeProperty ;
                                                                             rdfs:range xsd:boolean ;
                                                                             rdfs:comment "Indica si una entidad del censo de locales comerciales es pública o no."@es ,
                                                                                          "It points out whether an entity in the commerce census is public or not"@en ;
                                                                             rdfs:label "public"@en ,
                                                                                        "público"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion#budget
:budget rdf:type owl:DatatypeProperty ;
        rdfs:comment "Indica la estimación del coste de un evento o similar."@es ,
                     "It captures an estimate of expenditure for an event or something alike"@en ;
        rdfs:label "budget"@en ,
                   "presupuesto"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion#numberOfCommercialSpaces
:numberOfCommercialSpaces rdf:type owl:DatatypeProperty ;
                          rdfs:comment "It captures the number of commercial spaces joind to a campaign o something alike."@en ,
                                       "indica la cantidad de espacios comerciales adheridos a una campaña o similar."@es ;
                          rdfs:label "number of commercial spaces"@en ,
                                     "número de espacios comerciales"@es .


###  http://www.w3.org/2006/time#inXSDgYearMonth
<http://www.w3.org/2006/time#inXSDgYearMonth> rdf:type owl:DatatypeProperty ;
                                              rdfs:range xsd:gYearMonth ;
                                              rdfs:comment "Posición de un instante, expresado utilizando xsd:gYearMonth."@es ,
                                                           "Position of an instant, expressed using xsd:gYearMonth"@en ;
                                              rdfs:isDefinedBy <http://www.w3.org/2006/time#> ;
                                              rdfs:label "en año-mes gregoriano XSD"@es ,
                                                         "in XSD g-YearMonth"@en ;
                                              <http://www.w3.org/2004/02/skos/core#definition> "Posición de un instante, expresado utilizando xsd:gYearMonth."@es ,
                                                                                               "Position of an instant, expressed using xsd:gYearMonth"@en .


###  https://datos.ign.es/def/geo_core#xETRS89
<https://datos.ign.es/def/geo_core#xETRS89> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain <http://www.opengis.net/ont/sf#Point> ;
                                            rdfs:range xsd:float ;
                                            <http://purl.org/dc/elements/1.1/source> "Catálogo de Objetos Geográficos BTN100."@es ;
                                            rdfs:comment "Coordenada X en metros (ETRS89)"@es ,
                                                         "X-Coordinate in meters (ETRS89)"@en ;
                                            rdfs:isDefinedBy <https://datos.ign.es/def/geo_core#> ;
                                            rdfs:label "xETRS89" .


###  https://datos.ign.es/def/geo_core#yETRS89
<https://datos.ign.es/def/geo_core#yETRS89> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain <http://www.opengis.net/ont/sf#Point> ;
                                            rdfs:range xsd:float ;
                                            <http://purl.org/dc/elements/1.1/source> "Catálogo de Objetos Geográficos BTN100."@es ;
                                            rdfs:comment "Coordenada Y en metros (ETRS89)"@es ,
                                                         "Y-Coordinate in meters (ETRS89)"@en ;
                                            rdfs:isDefinedBy <https://datos.ign.es/def/geo_core#> ;
                                            rdfs:label "yETRS89" .


