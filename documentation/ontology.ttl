@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion#> .

<http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion> rdf:type owl:Ontology ;
                                                                   owl:versionIRI <http://vocab.linkeddata.es/datosabiertos/def/comercio/promocion/0.1.0> ;
                                                                   <http://purl.org/dc/terms/created> "2026-04-15" ;
                                                                   <http://purl.org/dc/terms/creator> "Daniel Doña" ,
                                                                                                      "Edna Ruckhaus" ,
                                                                                                      "Lucía Sánchez" ,
                                                                                                      "Oscar Corcho" ,
                                                                                                      "Socorro Bernardos" ;
                                                                   <http://purl.org/dc/terms/description> "El propósito de esta ontología es proporcionar un vocabulario común para la representación de las entidades y los datos principales relacionados con la promoción comercial, como campañas y eventos."@es ,
                                                                                                          "The purpose of this ontology is to provide a common vocabulary for representing the main entities and data related to commecial promotion, such as campaigns and events."@en ;
                                                                   <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                                                   <http://purl.org/dc/terms/title> "Ontología de Promoción Comercial"@es ,
                                                                                                    "The Commercial Promotion Ontology"@en ;
                                                                   <http://purl.org/vocab/vann/preferredNamespacePrefix> "edintpro" ;
                                                                   <http://purl.org/vocab/vann/preferredNamespaceUri> : ;
                                                                   owl:versionInfo "0.1.0" .

